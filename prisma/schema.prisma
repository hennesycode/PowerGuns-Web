generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum IdentificationType {
  cedula
  pasaporte
  cedula_extranjeria
}

enum UserRole {
  administrador
  finanzas
  editor
  cliente
  instructor
}

enum ReservationStatus {
  pending
  in_review
  confirmed
  completed
  canceled
}

enum GalleryMediaType {
  image
  video
}

enum PaymentMethodType {
  bank_transfer
  cash
}

enum PaymentProvider {
  cash
  daviplata
  nequi
  bancolombia
  davivienda
  bbva
}

model User {
  id                   Int                @id @default(autoincrement())
  username             String             @unique
  firstName            String
  lastName             String
  email                String             @unique
  identificationType   IdentificationType
  identificationNumber String             @unique
  role                 UserRole           @default(cliente)
  passwordHash         String
  isActive             Boolean            @default(true)
  avatarUrl            String?
  lastLoginAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  loginAttempts        LoginAttempt[]
  reservations         Reservation[]
  assignedCoupons      Coupon[]            @relation("AssignedCoupons")
  couponRedemptions    CouponRedemption[]
}

model LoginAttempt {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  email     String?
  ipAddress String?
  success   Boolean
  createdAt DateTime @default(now())
}

model Customer {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String
  email     String?
  createdAt DateTime  @default(now())
  bookings  Booking[]
}

model Service {
  id          Int       @id @default(autoincrement())
  name        String
  description String    @db.Text
  icon        String
  orderNum    Int       @default(0)
  createdAt   DateTime  @default(now())
  bookings    Booking[]
}

model Package {
  id          Int       @id @default(autoincrement())
  name        String
  tier        String
  tierLevel   Int
  description String    @db.Text
  price       Decimal   @db.Decimal(10, 2)
  unit        String    @default("COP por persona")
  features    String    @db.Text
  duration    String?
  isPopular   Boolean   @default(false)
  orderNum    Int       @default(0)
  createdAt   DateTime  @default(now())
  bookings    Booking[]
}

model AvailabilitySlot {
  id        Int       @id @default(autoincrement())
  date      DateTime
  startTime String
  endTime   String
  slots     Int       @default(6)
  createdAt DateTime  @default(now())
}

model Booking {
  id          Int       @id @default(autoincrement())
  customerId  Int
  customer    Customer  @relation(fields: [customerId], references: [id])
  serviceId   Int?
  service     Service?  @relation(fields: [serviceId], references: [id])
  packageId   Int?
  package     Package?  @relation(fields: [packageId], references: [id])
  date        DateTime
  startTime   String
  persons     Int       @default(1)
  status      String    @default("PENDING_VALIDATION")
  notes       String?   @db.Text
  accepted    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ContactLead {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String
  email     String?
  message   String?   @db.Text
  createdAt DateTime  @default(now())
}

model GalleryItem {
  id        String           @id @default(cuid())
  name      String
  mediaType GalleryMediaType
  fileUrl   String
  fileKey   String
  mimeType  String
  size      Int
  width     Int?
  height    Int?
  durationMs Int?
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([mediaType])
  @@index([sortOrder])
}

model PaymentMethod {
  id                   String            @id @default(cuid())
  type                 PaymentMethodType @default(bank_transfer)
  provider             PaymentProvider
  accountNumber        String
  accountHolderName    String
  identificationNumber String?
  isActive             Boolean           @default(true)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([provider])
  @@index([isActive])
}

model CompanySetting {
  id           String   @id
  companyName  String
  contactPhone String
  companyEmail String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum DiscountType {
  none
  percentage
  fixed
}

model TrainingService {
  id                Int           @id @default(autoincrement())
  name              String
  title             String
  slug              String        @unique
  mainImageUrl      String
  mainImageKey      String
  shortDescription  String
  longDescription   String        @db.Text
  seoTitle          String?
  seoDescription    String?
  seoKeywords       String?   @db.Text
  tags              String?   @db.Text
  price             Decimal       @db.Decimal(10, 2)
  discountType      DiscountType  @default(none)
  discountValue     Decimal?      @db.Decimal(10, 2)
  finalPrice        Decimal       @db.Decimal(10, 2)
  durationMinutes   Int
  includes          String        @db.Text
  isActive          Boolean       @default(true)
  isFeatured        Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  images            TrainingServiceImage[]

  @@index([slug])
  @@index([isActive])
}

model TrainingServiceImage {
  id                 Int             @id @default(autoincrement())
  serviceId          Int
  service            TrainingService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  imageUrl           String
  imageKey           String
  altText            String?
  sortOrder          Int             @default(0)
  createdAt          DateTime        @default(now())

  @@index([serviceId])
}

model Coupon {
  id              String       @id @default(cuid())
  code            String       @unique
  discountType    DiscountType
  discountValue   Int
  isActive        Boolean      @default(true)
  startsAt        DateTime?
  expiresAt       DateTime?
  maxUses         Int?
  perCustomerLimit Int?
  assignedUserId  Int?
  assignedUser    User?        @relation("AssignedCoupons", fields: [assignedUserId], references: [id], onDelete: SetNull)
  usedCount       Int          @default(0)
  minimumSubtotal Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  redemptions     CouponRedemption[]

  @@index([isActive])
  @@index([expiresAt])
  @@index([assignedUserId])
}

model CouponRedemption {
  id             String      @id @default(cuid())
  couponId       String
  coupon         Coupon      @relation(fields: [couponId], references: [id], onDelete: Cascade)
  reservationId  String?
  userId         Int?
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName   String
  customerEmail  String
  subtotal       Int
  discountAmount Int
  total          Int
  createdAt      DateTime    @default(now())

  @@index([couponId])
  @@index([reservationId])
  @@index([userId])
  @@index([customerEmail])
  @@index([createdAt])
}

model BusinessHour {
  id        String @id @default(cuid())
  dayOfWeek Int    @unique
  dayName   String
  isOpen    Boolean @default(false)
  slots     BusinessHourSlot[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dayOfWeek])
}

model BusinessHourSlot {
  id             String       @id @default(cuid())
  businessHourId String
  businessHour   BusinessHour @relation(fields: [businessHourId], references: [id], onDelete: Cascade)
  openTime       String
  closeTime      String
  sortOrder      Int          @default(0)

  @@index([businessHourId])
}

model Reservation {
  id                   String            @id @default(cuid())
  reservationCode      String            @unique

  userId               Int?
  user                 User?             @relation(fields: [userId], references: [id])

  firstName            String
  lastName             String
  identificationType   String
  identificationNumber String
  email                String
  phone                String
  address              String
  country              String            @default("Colombia")
  department           String
  city                 String

  reservationDate      DateTime
  reservationTime      String
  durationHours        Int               @default(1)
  durationMinutes      Int               @default(60)
  notes                String?           @db.Text

  status               ReservationStatus @default(pending)

  subtotal             Int
  discount             Int               @default(0)
  total                Int
  couponCode           String?
  paymentMethodLabel   String?

  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  items                ReservationItem[]

  @@unique([reservationDate, reservationTime])
  @@index([reservationDate])
  @@index([status])
  @@index([email])
  @@index([identificationNumber])
  @@index([userId])
}

model ReservationItem {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  serviceId     Int
  serviceTitle  String
  serviceSlug   String?
  imageUrl      String?
  unitPrice     Int
  quantity      Int
  hours         Int         @default(1)
  durationMinutes Int      @default(60)
  total         Int

  createdAt     DateTime    @default(now())

  @@index([reservationId])
  @@index([serviceId])
}

model InventoryCategory {
  id          String             @id @default(cuid())
  name        String
  slug        String             @unique
  description String?
  isActive    Boolean            @default(true)
  sortOrder   Int                @default(0)

  parentId    String?
  parent      InventoryCategory? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children    InventoryCategory[] @relation("CategoryHierarchy")

  products    InventoryProduct[]

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([parentId])
}

model InventoryProduct {
  id          String                    @id @default(cuid())
  name        String
  slug        String
  sku         String?                   @unique
  description String?
  quantity    Int                       @default(0)
  minStock    Int                       @default(0)
  location    String?
  isActive    Boolean                   @default(true)

  imageUrl    String?
  imageKey    String?
  imageAlt    String?

  categoryId  String
  category    InventoryCategory         @relation(fields: [categoryId], references: [id])

  history     InventoryProductHistory[]

  deletedAt   DateTime?

  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@index([categoryId])
  @@index([name])
  @@index([sku])
  @@index([isActive])
}

model ActivityLog {
  id                  String     @id @default(cuid())
  action              String
  entityType          String
  entityId            String?
  entityName          String?

  userId              Int?
  userFullName        String
  userUsername        String
  userIdentificationType String
  userIdentificationNumber String

  description         String     @db.Text
  status              String     @default("success")
  errorMessage        String?    @db.Text

  page                String?
  section             String?

  metadata            String?    @db.Text

  createdAt           DateTime   @default(now())

  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([status])
}

enum CertificateDccaeItemType {
  folder
  file
}

model CertificateDccaeItem {
  id          String                   @id @default(cuid())
  name        String
  type        CertificateDccaeItemType

  parentId    String?
  parent      CertificateDccaeItem?    @relation("CertificateDccaeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    CertificateDccaeItem[]   @relation("CertificateDccaeHierarchy")

  fileUrl     String?
  fileKey     String?
  mimeType    String?
  size        Int?
  extension   String?

  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([parentId])
  @@index([type])
  @@index([name])
}

model CertificateDccaeAuthorizedUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model InventoryProductHistory {
  id            String           @id @default(cuid())

  productId     String
  product       InventoryProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  action        String
  field         String?
  oldValue      String?
  newValue      String?
  note          String?

  changedByName String?

  createdAt     DateTime         @default(now())

  @@index([productId])
  @@index([createdAt])
}
